# Hosted (Netlify) build only -- leave all of these unset for the local
# desktop build (Electron/exe/browser-on-this-machine), which needs none of
# them and talks to the backend on the same machine instead.

# Set to "hosted" to enable sign-in and the upload-based onboarding flow.
# Leave unset (or anything else) for the local desktop build.
VITE_APP_MODE=

# Base URL of the backend hosted separately (e.g. on Render). Do not include
# a trailing /api -- that's appended automatically.
VITE_API_BASE_URL=

# From your Firebase project's Project Settings -> General -> "Your apps"
# web app config snippet. Safe to expose client-side (not a secret).
VITE_FIREBASE_API_KEY=
